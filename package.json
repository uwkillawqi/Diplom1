{
  "name": "meal-planner-msql",
  "version": "1.0.0",
  "private": true,
  "description": "Meal planner with MSSQL backend",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "schema": "node server/scripts/applySchema.js",
    "catalog:build": "node server/scripts/buildManualCatalog.js && node server/scripts/seedFromMock.js",
    "seed": "node server/scripts/seedFromMock.js",
    "db:setup": "node server/scripts/applySchema.js && node server/scripts/seedFromMock.js",
    "db:fix-nutrition": "node server/scripts/backfillIngredientNutrition.js",
    "recalc-portions": "node server/scripts/applyPortionScaleToAppJs.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^12.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
